# Copy to .env for local development. Never commit a real .env file.
# See plan.md section 10.5 for the full rationale behind each variable.

APP_ENV=local
HTTP_ADDR=:8080

# Only used by the worker process (the API exposes /metrics on HTTP_ADDR
# itself, alongside its regular routes) — plan.md section 22.1.
METRICS_ADDR=:9101

# Host-mapped ports for local development default to the plan's range and are
# used by Docker Compose. Change these when multiple stacks share the same host.
# If you run Go directly on the host, keep DATABASE_URL/REDIS_ADDR/
# OBJECT_STORAGE_ENDPOINT below in sync with these values.
POSTGRES_HOST_PORT=10001
REDIS_HOST_PORT=10002
API_HOST_PORT=10003
OBJECT_STORAGE_HOST_PORT=10004

# Inside the Docker network, services address each other by service name and
# internal port; the localhost addresses below are for host-run tools/processes.
DATABASE_URL=postgres://financial_manager:financial_manager@localhost:10001/financial_manager?sslmode=disable

REDIS_ADDR=localhost:10002
REDIS_PASSWORD=

OBJECT_STORAGE_ENDPOINT=localhost:10004
OBJECT_STORAGE_BUCKET=financial-manager-media
OBJECT_STORAGE_ACCESS_KEY=financial_manager
OBJECT_STORAGE_SECRET_KEY=financial_manager_secret
OBJECT_STORAGE_USE_SSL=false

# Comma-separated list of Google OAuth client IDs allowed as token audience.
# Leave empty in local/test until real client IDs are provisioned; Google
# sign-in requests will be rejected until this is set (see plan.md section 15.2).
GOOGLE_CLIENT_IDS=

# Required in production; local/test fall back to an insecure dev default.
JWT_SIGNING_KEY=
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=720h

# "stub" (default) uses a fake in-memory provider for local/test so the
# media search feature is exercisable without external credentials.
# "unsplash" requires IMAGE_SEARCH_API_KEY from unsplash.com/developers.
IMAGE_SEARCH_PROVIDER=stub
IMAGE_SEARCH_API_KEY=

MAX_UPLOAD_BYTES=10485760
ALLOWED_IMAGE_TYPES=image/jpeg,image/png,image/webp
